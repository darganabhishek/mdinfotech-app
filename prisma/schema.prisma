generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int            @id @default(autoincrement())
  name             String
  username         String         @unique
  password         String
  roleId           Int?
  role             Role?          @relation(fields: [roleId], references: [id])
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  auditLogs        AuditLog[]
  student          Student?
  faculty          Faculty?
  markedAttendances Attendance[]
  notifications    Notification[]
  deviceRegistration DeviceRegistration?
  securityAlerts   SecurityAlert[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g., "manage_students", "view_reports"
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Faculty {
  id             Int       @id @default(autoincrement())
  userId         Int?      @unique
  user           User?     @relation(fields: [userId], references: [id])
  name           String
  email          String    @default("")
  phone          String    @default("")
  qualification  String    @default("")
  specialization String    @default("") // Subjects/Courses taught
  joiningDate    String?
  salary         Float     @default(0)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  batches        Batch[]
  assignments    Assignment[]
  resources      ElearningResource[]
  timetableSlots TimetableSlot[]
  clockLogs      FacultyClockLog[]
  sessions       AttendanceSession[]
}

model Student {
  id           Int         @id @default(autoincrement())
  userId       Int?        @unique
  user         User?       @relation(fields: [userId], references: [id])
  enrollmentNo String      @unique
  name         String
  fatherName   String      @default("")
  motherName   String      @default("")
  phone        String      @default("")
  email        String      @default("")
  address      String      @default("")
  city         String      @default("")
  state        String      @default("")
  pincode      String      @default("")
  dob          String      @default("")
  gender       String      @default("")
  qualification String     @default("")
  photo        String      @default("")
  aadhaarNo    String      @default("")
  prevKnowledge String     @default("")
  status       String      @default("active")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  admissions   Admission[]
  attendances  Attendance[]
  submissions  Submission[]
  referrals    Referral[]   @relation("Referrer")
}

model Course {
  id           Int         @id @default(autoincrement())
  name         String
  code         String      @unique
  duration     Int         @default(3)
  durationUnit String      @default("months")
  fee          Float       @default(0)
  description  String      @default("")
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  batches      Batch[]
  admissions   Admission[]
  resources    ElearningResource[]
}

model Batch {
  id         Int         @id @default(autoincrement())
  name       String
  courseId    Int
  course     Course      @relation(fields: [courseId], references: [id])
  startDate  String      @default("")
  endDate    String      @default("")
  timing     String      @default("")
  timeSlotId Int?
  timeSlot   TimeSlot?   @relation(fields: [timeSlotId], references: [id])
  facultyId   Int?
  faculty    Faculty?    @relation(fields: [facultyId], references: [id])
  capacity   Int         @default(20)
  status     String      @default("active")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  admissions Admission[]
  attendances Attendance[]
  assignments Assignment[]
  timetableSlots TimetableSlot[]
  sessions   AttendanceSession[]
}

model Admission {
  id            Int           @id @default(autoincrement())
  studentId     Int
  student       Student       @relation(fields: [studentId], references: [id])
  courseId       Int
  course        Course        @relation(fields: [courseId], references: [id])
  batchId       Int
  batch         Batch         @relation(fields: [batchId], references: [id])
  admissionDate String
  totalFee      Float         @default(0)
  discount      Float         @default(0)
  netFee        Float         @default(0)
  paymentPlan   String        @default("monthly") // "full" or "monthly"
  installmentAmount Float?
  installmentsCount Int?
  status        String        @default("active")
  notes         String        @default("")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  payments      Payment[]
  certificates  Certificate[]
}

model Payment {
  id          Int       @id @default(autoincrement())
  admissionId Int
  admission   Admission @relation(fields: [admissionId], references: [id])
  amount      Float
  paymentDate String
  paymentMode String    @default("cash")
  paymentMonth String?  // e.g., "Jan 2026"
  receiptNo   String    @unique
  reference   String    @default("")
  notes       String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Enquiry {
  id              Int      @id @default(autoincrement())
  name            String
  phone           String   @default("")
  email           String   @default("")
  courseInterested String   @default("")
  source          String   @default("walk-in")
  followUpDate    String   @default("")
  status          String   @default("new")
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Certificate {
  id            Int       @id @default(autoincrement())
  admissionId   Int
  admission     Admission @relation(fields: [admissionId], references: [id])
  certificateNo String    @unique
  issueDate     String
  grade         String    @default("")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  Int      @default(0)
  details   String   @default("")
  createdAt DateTime @default(now())
}

model Referral {
  id              Int      @id @default(autoincrement())
  referrerStudentId Int
  referrerStudent Student  @relation("Referrer", fields: [referrerStudentId], references: [id])
  referredName    String
  referredPhone   String   @default("")
  referredEmail   String   @default("")
  courseInterested String  @default("")
  status          String   @default("pending") // "pending", "enrolled", "rewarded"
  rewardAmount    Float    @default(0)
  rewardPaid      Boolean  @default(false)
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Settings {
  id            Int      @id @default(1)
  instituteName String   @default("M.D. INFOTECH")
  tagline       String   @default("Professional Computer Institute")
  address       String   @default("123 Tech Lane, Digital City, 54321")
  phone         String   @default("+91 9716161624")
  email         String   @default("itmdinfotech@gmail.com")
  updatedAt     DateTime @updatedAt
}

model Attendance {
  id                  Int               @id @default(autoincrement())
  date                String            // YYYY-MM-DD
  status              String            // "present", "absent", "late"
  studentId           Int
  student             Student           @relation(fields: [studentId], references: [id])
  batchId             Int
  batch               Batch             @relation(fields: [batchId], references: [id])
  markedById          Int
  markedBy            User              @relation(fields: [markedById], references: [id])
  notes               String?
  deviceFingerprint   String?
  latitude            Float?
  longitude           Float?
  verificationMethod  String            @default("manual") // "manual", "qr", "qr+face"
  sessionId           Int?
  session             AttendanceSession? @relation(fields: [sessionId], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([date, studentId, batchId])
}

model Assignment {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  dueDate     String
  batchId     Int
  batch       Batch        @relation(fields: [batchId], references: [id])
  facultyId   Int
  faculty     Faculty      @relation(fields: [facultyId], references: [id])
  attachments String?      // JSON string of file URLs
  submissions Submission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Submission {
  id           Int        @id @default(autoincrement())
  assignmentId  Int
  assignment    Assignment @relation(fields: [assignmentId], references: [id])
  studentId     Int
  student       Student    @relation(fields: [studentId], references: [id])
  content       String?    // Text submission
  fileUrl       String?    // Uploaded file
  grade         String?
  feedback      String?
  submittedAt   DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([assignmentId, studentId])
}

model ElearningResource {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  type        String   // "video", "pdf", "link", "doc"
  url         String
  courseId    Int?
  course      Course?  @relation(fields: [courseId], references: [id])
  facultyId   Int?
  faculty     Faculty? @relation(fields: [facultyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  title       String
  message     String
  type        String   // "info", "warning", "success", "error"
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())
}

model TimetableSlot {
  id          Int      @id @default(autoincrement())
  day         String   // "Monday", "Tuesday", etc.
  startTime   String   // "09:00"
  endTime     String   // "10:30"
  subject     String
  room        String   @default("")
  batchId     Int
  batch       Batch    @relation(fields: [batchId], references: [id])
  facultyId   Int
  faculty     Faculty  @relation(fields: [facultyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([day, startTime, batchId])
  @@unique([day, startTime, facultyId])
}

model TimeSlot {
  id        Int      @id @default(autoincrement())
  startTime String   // "09:00"
  endTime   String   // "10:00"
  label     String   // "09:00 AM - 10:00 AM"
  batches   Batch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resource {
  id          Int      @id @default(autoincrement())
  name        String
  category    String   // "lab_computer", "software_license", "projector", "room"
  description String?
  quantity    Int      @default(1)
  available   Int      @default(1)
  location    String   @default("")
  status      String   @default("available") // "available", "in_use", "maintenance"
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DeviceRegistration {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
  fingerprint String
  userAgent   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AttendanceSession {
  id          Int          @id @default(autoincrement())
  batchId     Int
  batch       Batch        @relation(fields: [batchId], references: [id])
  facultyId   Int
  faculty     Faculty      @relation(fields: [facultyId], references: [id])
  qrSecret    String       @unique
  startTime   DateTime     @default(now())
  endTime     DateTime?
  latitude    Float        @default(0)
  longitude   Float        @default(0)
  radius      Int          @default(100)
  active      Boolean      @default(true)
  attendances Attendance[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model SecurityAlert {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  type      String   // "duplicate_device", "gps_spoof", "outside_radius", "failed_attempt"
  message   String
  details   String   @default("")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model FacultyClockLog {
  id          Int      @id @default(autoincrement())
  facultyId   Int
  faculty     Faculty  @relation(fields: [facultyId], references: [id])
  clockIn     DateTime
  clockOut    DateTime?
  totalHours  Float?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())
}
