generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  name               String
  username           String              @unique
  password           String
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  roleId             Int?
  markedAttendances  Attendance[]
  auditLogs          AuditLog[]
  deviceRegistration DeviceRegistration?
  faculty            Faculty?
  notifications      Notification[]
  securityAlerts     SecurityAlert[]
  student            Student?
  createdSessions    AttendanceSession[] @relation("SessionCreator")
  role               Role?               @relation(fields: [roleId], references: [id])
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("PermissionToRole")
}

model Faculty {
  id             Int                 @id @default(autoincrement())
  userId         Int?                @unique
  name           String
  email          String              @default("")
  phone          String              @default("")
  qualification  String              @default("")
  specialization String              @default("")
  joiningDate    String?
  salary         Float               @default(0)
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  assignments    Assignment[]
  sessions       AttendanceSession[]
  batches        Batch[]
  resources      ElearningResource[]
  user           User?               @relation(fields: [userId], references: [id])
  clockLogs      FacultyClockLog[]
  timetableSlots TimetableSlot[]
}

model Student {
  id            Int          @id @default(autoincrement())
  enrollmentNo  String       @unique
  name          String
  fatherName    String       @default("")
  motherName    String       @default("")
  phone         String       @default("")
  email         String       @default("")
  address       String       @default("")
  city          String       @default("")
  state         String       @default("")
  pincode       String       @default("")
  dob           String       @default("")
  gender        String       @default("")
  qualification String       @default("")
  photo         String       @default("")
  aadhaarNo     String       @default("")
  prevKnowledge String       @default("")
  status        String       @default("active")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  userId        Int?         @unique
  admissions    Admission[]
  attendances   Attendance[]
  referrals     Referral[]   @relation("Referrer")
  user          User?        @relation(fields: [userId], references: [id])
  submissions   Submission[]
  notices       Notice[]
}

model Course {
  id           Int                 @id @default(autoincrement())
  name         String
  code         String              @unique
  duration     Int                 @default(3)
  durationUnit String              @default("months")
  fee          Float               @default(0)
  description  String              @default("")
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  admissions   Admission[]
  batches      Batch[]
  resources    ElearningResource[]
  topics       Topic[]
  notices      Notice[]
}

model Topic {
  id          Int          @id @default(autoincrement())
  name        String
  courseId    Int
  course      Course       @relation(fields: [courseId], references: [id])
  assignments Assignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Batch {
  id             Int                 @id @default(autoincrement())
  name           String
  courseId       Int
  startDate      String              @default("")
  endDate        String              @default("")
  timing         String              @default("")
  capacity       Int                 @default(20)
  status         String              @default("active")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  facultyId      Int?
  timeSlotId     Int?
  admissions     Admission[]
  assignments    Assignment[]
  attendances    Attendance[]
  sessions       AttendanceSession[]
  course         Course              @relation(fields: [courseId], references: [id])
  faculty        Faculty?            @relation(fields: [facultyId], references: [id])
  timeSlot       TimeSlot?           @relation(fields: [timeSlotId], references: [id])
  timetableSlots TimetableSlot[]
}

model Admission {
  id                Int           @id @default(autoincrement())
  studentId         Int
  courseId          Int
  batchId           Int?
  admissionDate     String
  totalFee          Float         @default(0)
  discount          Float         @default(0)
  netFee            Float         @default(0)
  status            String        @default("active")
  notes             String        @default("")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  installmentAmount Float?
  installmentsCount Int?
  paymentPlan       String        @default("monthly")
  batch             Batch?        @relation(fields: [batchId], references: [id])
  course            Course        @relation(fields: [courseId], references: [id])
  student           Student       @relation(fields: [studentId], references: [id])
  certificates      Certificate[]
  payments          Payment[]
}

model Payment {
  id           Int       @id @default(autoincrement())
  admissionId  Int
  amount       Float
  paymentDate  String
  paymentMode  String    @default("cash")
  receiptNo    String    @unique
  reference    String    @default("")
  notes        String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  paymentMonth String?
  discount     Float     @default(0)
  admission    Admission @relation(fields: [admissionId], references: [id])
}

model Enquiry {
  id               Int      @id @default(autoincrement())
  name             String
  phone            String   @default("")
  email            String   @default("")
  courseInterested String   @default("")
  source           String   @default("walk-in")
  followUpDate     String   @default("")
  status           String   @default("new")
  notes            String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Certificate {
  id            Int       @id @default(autoincrement())
  admissionId   Int
  certificateNo String    @unique
  issueDate     String
  grade         String    @default("")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  admission     Admission @relation(fields: [admissionId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int      @default(0)
  details   String   @default("")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Referral {
  id                Int      @id @default(autoincrement())
  referrerStudentId Int
  referredName      String
  referredPhone     String   @default("")
  referredEmail     String   @default("")
  courseInterested  String   @default("")
  status            String   @default("pending")
  rewardAmount      Float    @default(0)
  rewardPaid        Boolean  @default(false)
  notes             String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  referrerStudent   Student  @relation("Referrer", fields: [referrerStudentId], references: [id])
}

model Settings {
  id            Int      @id @default(1)
  instituteName String   @default("M.D. INFOTECH")
  tagline       String   @default("Professional Computer Institute")
  address       String   @default("123 Tech Lane, Digital City, 54321")
  phone         String   @default("+91 9716161624")
  email         String   @default("itmdinfotech@gmail.com")
  updatedAt     DateTime @updatedAt
}

model Attendance {
  id                 Int                @id @default(autoincrement())
  date               String
  status             String
  studentId          Int
  batchId            Int
  markedById         Int
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deviceFingerprint  String?
  latitude           Float?
  longitude          Float?
  sessionId          Int?
  verificationMethod String             @default("manual")
  batch              Batch              @relation(fields: [batchId], references: [id])
  markedBy           User               @relation(fields: [markedById], references: [id])
  session            AttendanceSession? @relation(fields: [sessionId], references: [id])
  student            Student            @relation(fields: [studentId], references: [id])

  @@unique([date, studentId, batchId])
}

model Assignment {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  dueDate     String
  batchId     Int
  facultyId   Int
  attachments String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  topicId     Int?
  isLocked    Boolean      @default(false)
  batch       Batch        @relation(fields: [batchId], references: [id])
  faculty     Faculty      @relation(fields: [facultyId], references: [id])
  topic       Topic?       @relation(fields: [topicId], references: [id])
  submissions Submission[]
}

model Submission {
  id           Int        @id @default(autoincrement())
  assignmentId Int
  studentId    Int
  content      String?
  fileUrl      String?
  grade        String?
  feedback     String?
  submittedAt  DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  student      Student    @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
}

model ElearningResource {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  type        String
  url         String
  courseId    Int?
  facultyId   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course?  @relation(fields: [courseId], references: [id])
  faculty     Faculty? @relation(fields: [facultyId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model TimetableSlot {
  id        Int      @id @default(autoincrement())
  day       String
  startTime String
  endTime   String
  subject   String
  room      String   @default("")
  batchId   Int
  facultyId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batch     Batch    @relation(fields: [batchId], references: [id])
  faculty   Faculty  @relation(fields: [facultyId], references: [id])

  @@unique([day, startTime, batchId])
  @@unique([day, startTime, facultyId])
}

model TimeSlot {
  id        Int      @id @default(autoincrement())
  startTime String
  endTime   String
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batches   Batch[]
  sessions  AttendanceSession[]
}

model Resource {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  description String?
  quantity    Int      @default(1)
  available   Int      @default(1)
  location    String   @default("")
  status      String   @default("available")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DeviceRegistration {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  fingerprint String
  userAgent   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model AttendanceSession {
  id          Int          @id @default(autoincrement())
  batchId     Int?
  timeSlotId  Int?
  facultyId   Int?
  creatorId   Int?
  qrSecret    String       @unique
  startTime   DateTime     @default(now())
  endTime     DateTime?
  latitude    Float        @default(0)
  longitude   Float        @default(0)
  radius      Int          @default(100)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]
  batch       Batch?       @relation(fields: [batchId], references: [id])
  timeSlot    TimeSlot?    @relation(fields: [timeSlotId], references: [id])
  faculty     Faculty?     @relation(fields: [facultyId], references: [id])
  creator     User?        @relation("SessionCreator", fields: [creatorId], references: [id])
}

model SecurityAlert {
  id        Int      @id @default(autoincrement())
  userId    Int?
  type      String
  message   String
  details   String   @default("")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model FacultyClockLog {
  id         Int       @id @default(autoincrement())
  facultyId  Int
  clockIn    DateTime
  clockOut   DateTime?
  totalHours Float?
  latitude   Float?
  longitude  Float?
  faceImage  String?   @default("")
  createdAt  DateTime  @default(now())
  faculty    Faculty   @relation(fields: [facultyId], references: [id])
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  type      String   @default("text") // text, file, link, document
  fileUrl   String?
  link      String?
  target    String   @default("all") // all, course, student
  courseId  Int?
  studentId Int?
  course    Course?  @relation(fields: [courseId], references: [id])
  student   Student? @relation(fields: [studentId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobPost {
  id          Int      @id @default(autoincrement())
  title       String
  company     String
  description String
  location    String?
  link        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
